{
  "name": "SignalFlow",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "forwardPorts": [8080],
  "postCreateCommand": "npm install",
  "postStartCommand": "npm start",
  "portsAttributes": {
    "8080": {
      "label": "SignalFlow App",
      "onAutoForward": "openBrowser"
    }
  }
}
